# Apify API token — get yours at https://console.apify.com/account#/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# Your wallet address to receive Tempo/PathUSD payments
# Generate one at https://app.tempo.finance or use any EVM-compatible wallet
RECIPIENT_ADDRESS=0xYourWalletAddressHere

# Server port (optional, defaults to 3000)
PORT=3000
